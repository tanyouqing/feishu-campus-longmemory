LONGMEMORY_ENV=local
LONGMEMORY_HOST=127.0.0.1
LONGMEMORY_PORT=8000
LONGMEMORY_DATABASE_URL=sqlite:///./data/longmemory.db
LONGMEMORY_LOG_LEVEL=INFO
LONGMEMORY_INGEST_TOKEN=replace-with-a-strong-random-token
LONGMEMORY_FEISHU_VERIFICATION_TOKEN=
LONGMEMORY_FEISHU_ENCRYPT_KEY=
LONGMEMORY_FEISHU_APP_ID=
LONGMEMORY_FEISHU_APP_SECRET=
LONGMEMORY_FEISHU_DOMAIN=feishu
LONGMEMORY_FEISHU_DEFAULT_RECEIVE_ID_TYPE=open_id
LONGMEMORY_CONTEXT_LIMIT=5
LONGMEMORY_CONTEXT_ENABLED=true
LONGMEMORY_REMINDER_SCHEDULER_ENABLED=false
LONGMEMORY_REMINDER_POLL_INTERVAL_SECONDS=30
LONGMEMORY_REMINDER_BATCH_SIZE=10
